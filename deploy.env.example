# SoundMaster FTP デプロイ設定
# このファイルを deploy.env にコピーして編集してください

# FTPサーバー
FTP_SERVER=ftp.example.com

# FTPユーザー
FTP_USER=your_account

# FTPパスワード
FTP_PASS=your_password

# リモートパス（public_html以降）
FTP_REMOTE_PATH=/public_html/soundmaster

# パッシブモード（1=有効, 0=無効）
FTP_PASSIVE_MODE=1

# SSL使用（1=有効, 0=無効）
FTP_USE_SSL=0

# ミラーリング時に削除（1=有効, 0=無効）
FTP_MIRROR_DELETE=1
